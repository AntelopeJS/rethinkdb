{
  "name": "@antelopejs/rethinkdb",
  "version": "0.1.2",
  "description": "RethinkDB module that implements the Database interface of antelopejs",
  "keywords": [
    "antelopejs",
    "rethinkdb",
    "database",
    "nosql",
    "realtime"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/rethinkdb.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "generate": "ajs module exports generate",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "prepare": "ajs module imports install",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && release-it",
    "typecheck": "tsc --noEmit",
    "test": "npx tsc && ajs module test"
  },
  "antelopeJs": {
    "exportsPath": "dist/interfaces",
    "imports": [
      "core@beta",
      "logging@beta"
    ],
    "importsOptional": [],
    "test": {
      "project": "src/test/testproject.js",
      "folder": "dist/test"
    },
    "defaultConfig": {
      "pool": {
        "pool": true,
        "cursor": false,
        "silent": true,
        "user": "admin",
        "password": "",
        "discovery": true,
        "host": "127.0.0.1",
        "port": "28015"
      }
    }
  },
  "dependencies": {
    "chai": "^4.5.0",
    "reflect-metadata": "^0.2.2",
    "rethinkdb-ts": "^2.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/chai": "^4.3.3",
    "@types/mocha": "^10.0.10",
    "rimraf": "^6.0.1",
    "@types/node": "^22.14.1",
    "release-it": "^19.0.2",
    "release-it-changelogen": "^0.1.0",
    "typescript": "^5.8.3"
  }
}
